APP_NAME=Goal Stream API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10
LOG_LEVEL=INFO
LOG_JSON=false
NEWS_PROVIDER=gnews

FOOTBALL_DATA_BASE_URL=https://apiv3.apifootball.com
FOOTBALL_DATA_API_KEY=your-apifootball-key
FOOTBALL_DATA_TIMEZONE=Asia/Riyadh
FOOTBALL_DATA_FIXTURE_CACHE_PATH=

GNEWS_BASE_URL=https://gnews.io/api/v4
GNEWS_API_KEY=your-gnews-api-key
GNEWS_MAX_RESULTS=10
CACHE_DEFAULT_TTL_SECONDS=300
CACHE_REDIRECT_CONFIG_TTL_SECONDS=30
REDIS_URL=
REDIS_KEY_PREFIX=goal-stream
CACHE_STALE_TTL_SECONDS=604800

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=goal_stream
DATABASE_USER=goal_stream
DATABASE_PASSWORD=goal_stream
DATABASE_URL=
SYNC_DATABASE_URL=

CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ADMIN_BOOTSTRAP_USERNAME=
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
